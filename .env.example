# =========================================
# S.A.V.O.R.I Environment Variables Template
# =========================================
# DO NOT put your real API keys in this file.
# Copy this file to .env.local and fill in the values.

# ── SUPABASE (Database & Auth) ──
# Dapatkan dari Dashboard Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=ey...

# ── APPLICATION ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── AI MODELS (Vision, Voice & Analytics) ──

# Groq API (Untuk Whisper Speech-to-Text & Llama Analytics)
# Dapatkan di: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Gemini API (Fallback Vision Model)
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AI...

# Qwen 2.5 VL Configuration (Primary Vision Model via OpenRouter)
# Dapatkan di: https://openrouter.ai/keys
VISION_ENGINE=qwen
QWEN_API_KEY=sk-or-v1-...
QWEN_BASE_URL=https://openrouter.ai/api/v1
QWEN_MODEL_NAME=qwen/qwen-2.5-vl-72b-instruct

# ── PYTHON MICROSERVICE (XGBoost Forecasting) ──
# URL tempat FastAPI berjalan (biasanya localhost port 8000)
FORECAST_API_URL=http://127.0.0.1:8000/predict
